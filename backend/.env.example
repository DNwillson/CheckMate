# Copy to .env and fill in. Used for MySQL and JWT.
# Note: backend loads this file with override=True so edits here win over empty shell vars.

JWT_SECRET_KEY=change-me-to-a-long-random-string

# Local or generic (you may use PORT / USER / PASSWORD / DATABASE instead of MYSQL_*)
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your-password
MYSQL_DATABASE=checkmate

# Aiven: TLS is auto-enabled when MYSQL_HOST contains aivencloud.com; or force:
# MYSQL_SSL_REQUIRED=1
# If certificate verification fails, point to the CA file from the Aiven console:
# MYSQL_SSL_CA=./certs/ca.pem

# Optional full URL (then MYSQL_* can be omitted):
# DATABASE_URL=mysql+pymysql://root:password@127.0.0.1:3306/checkmate?charset=utf8mb4

# --- AI for /api/assistant/reply ---
# If AI_PROVIDER is empty, the server tries (in order): moonshot → deepseek → siliconflow → dashscope → gemini.
# Pick one key below (or set AI_PROVIDER to force one backend).

# Moonshot / Kimi (mainland-friendly): https://platform.moonshot.cn/
# MOONSHOT_API_KEY=sk-...
# MOONSHOT_MODEL=moonshot-v1-8k
# MOONSHOT_BASE_URL=https://api.moonshot.cn/v1/chat/completions

# DeepSeek: https://platform.deepseek.com/
# DEEPSEEK_API_KEY=sk-...
# DEEPSEEK_MODEL=deepseek-chat

# SiliconFlow 硅基流动: https://siliconflow.cn/
# SILICONFLOW_API_KEY=sk-...
# SILICONFLOW_MODEL=Qwen/Qwen2.5-7B-Instruct

# Alibaba DashScope 通义 (OpenAI-compatible): https://help.aliyun.com/zh/model-studio/
# DASHSCOPE_API_KEY=sk-...
# DASHSCOPE_MODEL=qwen-turbo

# Google Gemini: https://aistudio.google.com/apikey
# GEMINI_API_KEY=...
# GEMINI_MODEL=gemini-2.0-flash

# Force a single backend: moonshot | deepseek | siliconflow | dashscope | gemini
# AI_PROVIDER=moonshot

# --- Weather for GET /api/weather (Open-Meteo, no key) ---
# If the app does not send lat/lon, the server uses default city geocoding:
# WEATHER_DEFAULT_CITY=Shanghai
# Or pin coordinates (skips geocode for default request):
# WEATHER_DEFAULT_LAT=31.2304
# WEATHER_DEFAULT_LON=121.4737
# WEATHER_DEFAULT_LABEL=Shanghai, CN
